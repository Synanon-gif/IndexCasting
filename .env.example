# Copy to .env.local and set values from Supabase Dashboard → Project Settings → API.
# Required names for Expo (use these in Vercel Production too):
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Do not use SUPABASE_URL / SUPABASE_ANON_KEY alone — app.config maps them only as fallback.
# Optional; used when your project relies on the publishable default key.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# --- Local Supabase CLI (optional): migrations / functions deploy ---
# SUPABASE_ACCESS_TOKEN=   # from `npx supabase login` or dashboard access token
# SUPABASE_PROJECT_REF=    # project ref (Settings → General), same as in supabase/config.toml comment

# --- GitHub Actions repository secrets (do not commit real values) ---
# CI / Deploy tests:
#   EXPO_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY
# Vercel deploy (deploy.yml):
#   VERCEL_TOKEN
#   VERCEL_ORG_ID
#   VERCEL_PROJECT_ID
# Supabase Edge Functions auto-deploy (supabase-edge-functions.yml):
#   SUPABASE_ACCESS_TOKEN
#   SUPABASE_PROJECT_REF
