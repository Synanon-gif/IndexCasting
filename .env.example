# Copy to .env.local and set values from Supabase Dashboard → Project Settings → API.
# Required names for Expo (use these in Vercel Production too):
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# --- Sentry (Error Monitoring, optional in dev) ---
# Lokal/Development: leer lassen → Sentry ist no-op.
# Preview/Production: DSN aus dem Sentry-Projekt eintragen (org "index-casting", project "react-native").
# Verwende AUSSCHLIESSLICH den Public-Client-DSN — niemals den Auth-Token.
# EXPO_PUBLIC_SENTRY_DSN=https://xxxxxxx@oXXXX.ingest.de.sentry.io/XXXXX
# Steuert die Sentry environment-Tag (development|preview|production).
# Default: development → Sentry deaktiviert.
# EXPO_PUBLIC_APP_ENV=production
# Do not use SUPABASE_URL / SUPABASE_ANON_KEY alone — app.config maps them only as fallback.
# Optional; used when your project relies on the publishable default key.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# --- EAS / Push Notifications (required for native push on iOS/Android) ---
# Get your project ID from https://expo.dev → Project → Settings → EAS Project ID
EAS_PROJECT_ID=

# --- Local Supabase CLI (optional): migrations / functions deploy ---
# SUPABASE_ACCESS_TOKEN=   # from `npx supabase login` or dashboard access token
# SUPABASE_PROJECT_REF=    # project ref (Settings → General), same as in supabase/config.toml comment

# --- GitHub Actions repository secrets (do not commit real values) ---
# CI / Deploy tests:
#   EXPO_PUBLIC_SUPABASE_URL
#   EXPO_PUBLIC_SUPABASE_ANON_KEY
# Vercel deploy (deploy.yml):
#   VERCEL_TOKEN
#   VERCEL_ORG_ID
#   VERCEL_PROJECT_ID
# Supabase Edge Functions auto-deploy (supabase-edge-functions.yml):
#   SUPABASE_ACCESS_TOKEN
#   SUPABASE_PROJECT_REF
#
# Live-DB-Metadaten-Export (lokal: npm run export:db-state → CHATGPT_LIVE_DB_STATE.txt):
#   SUPABASE_ACCESS_TOKEN + SUPABASE_PROJECT_REF (wie oben)

# --- Email delivery (Resend) — set via Supabase Secrets ---
# npx supabase secrets set RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx --project-ref ispkfdqzjrfrilosoklu
# Get your API key at https://resend.com → API Keys
# Set to 1 while using Stripe test mode so the app can show an explicit test-mode notice (owner billing card).
# EXPO_PUBLIC_STRIPE_SANDBOX=1

# Required for: invite emails (booker, employee, model claim)

# --- Public app URL (Expo / Vercel) — password reset + Stripe redirect allowlist ---
# EXPO_PUBLIC_APP_URL=https://your-production-domain.com

# --- Stripe Live readiness (placeholders — real values in Supabase Edge secrets + Stripe Dashboard) ---
# Set on Supabase Edge Functions (create-checkout-session, stripe-webhook), e.g. npx supabase secrets set ...
#   STRIPE_SECRET_KEY=sk_live_... or sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...   (from Stripe webhook endpoint signing secret)
#   STRIPE_PRICE_AGENCY_BASIC=price_...
#   STRIPE_PRICE_AGENCY_PRO=price_...
#   STRIPE_PRICE_AGENCY_ENTERPRISE=price_...
#   STRIPE_PRICE_CLIENT=price_...
#   APP_URL=https://your-production-domain.com
# Also: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY (usually auto-provided).
# For Live: replace test keys and price IDs with Live mode values; use Live webhook secret only on Live endpoint.
