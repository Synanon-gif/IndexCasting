{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "npx expo start",
    "android": "npx expo start --android",
    "ios": "npx expo start --ios",
    "web": "npx expo start --web",
    "web:lan": "WEB_HOST=0.0.0.0 npx expo start --web",
    "build": "npx expo export --platform web",
    "build:web": "npx expo export --platform web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:public": "playwright test e2e/public-pages.spec.ts",
    "test:e2e:auth": "playwright test e2e/auth.spec.ts",
    "test:e2e:guest": "playwright test e2e/guest-link.spec.ts",
    "test:e2e:upload": "playwright test e2e/upload-consent.spec.ts",
    "test:all": "jest && playwright test",
    "lint": "eslint 'src/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}' --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}'",
    "sync": "bash scripts/sync-dev.sh",
    "deploy:supabase:functions": "bash scripts/deploy-supabase-functions.sh",
    "review-context": "bash scripts/generate-llm-review-bundle.sh",
    "security-audit-bundle": "bash scripts/generate-security-audit-bundle.sh",
    "audit:coverage": "node scripts/audit-coverage.mjs",
    "prepare": "husky",
    "cap:sync": "cap sync",
    "cap:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@supabase/supabase-js": "^2.99.0",
    "browser-image-compression": "^2.0.2",
    "expo": "~55.0.5",
    "expo-constants": "^55.0.7",
    "expo-image-picker": "~17.0.8",
    "expo-notifications": "^55.0.16",
    "expo-status-bar": "~55.0.4",
    "heic2any": "^0.0.4",
    "i18n-iso-countries": "^7.14.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@playwright/test": "^1.59.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "dotenv": "^17.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.8.1",
    "supabase": "^2.84.6",
    "ts-jest": "^29.2.5",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "{src,lib}/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "capacitor": {
    "ios": {
      "path": "ios"
    }
  },
  "private": true
}
